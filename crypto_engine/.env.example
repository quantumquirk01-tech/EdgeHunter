
# --- API Keys (Fill these with your actual keys) ---
# It's recommended to use read-only keys for scraping/data gathering if possible,
# and keys with trade permissions only for the execution engine.
BINANCE_API_KEY="YOUR_BINANCE_API_KEY"
BINANCE_API_SECRET="YOUR_BINANCE_API_SECRET"

BYBIT_API_KEY="YOUR_BYBIT_API_KEY"
BYBIT_API_SECRET="YOUR_BYBIT_API_SECRET"

KUCOIN_API_KEY="YOUR_KUCOIN_API_KEY"
KUCOIN_API_SECRET="YOUR_KUCOIN_API_SECRET"
KUCOIN_API_PASSPHRASE="YOUR_KUCOIN_API_PASSPHRASE"

GATEIO_API_KEY="YOUR_GATEIO_API_KEY"
GATEIO_API_SECRET="YOUR_GATEIO_API_SECRET"

# Optional: For market data enrichment
CMC_API_KEY="YOUR_COINMARKETCAP_API_KEY"

# --- Telegram Bot (For notifications) ---
# Create a bot with @BotFather on Telegram to get a token
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
# Get your chat ID from a bot like @userinfobot
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID"

# --- Database & Cache ---
# Connection string for PostgreSQL and Redis. 
# Assumes they are running locally. Change if using Docker containers with specific hostnames.
DATABASE_URL="postgresql+asyncpg://crypto_user:strong_password@localhost/crypto_db"
REDIS_URL="redis://localhost:6379"

# --- Security ---
# A strong, random secret key for JWT tokens or other security features.
# You can generate one using: openssl rand -hex 32
SECRET_KEY="change_this_to_a_very_strong_random_secret_key"

GITHUB_TOKEN="YOUR_GITHUB_TOKEN"
VCELCEL_TOKEN="YOUR_VERCEL_TOKEN"


